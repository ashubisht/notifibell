{
  "name": "notifibell",
  "version": "2.0.0",
  "description": "Send SMS, email, and notifications using AWS SNS and SES",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx ./src/index.ts",
    "build:scraper": "npm run build --prefix extract_institutes",
    "postinstall": "npm run build:scraper",
    "compile": "npm run build:scraper && rimraf ./dist/ && tsc -b ./tsconfig.compile.json",
    "build": "tsc -b ./tsconfig.compile.json",
    "rmdist": "rimraf ./dist/",
    "typecheck": "tsc -b",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashubisht/notifibell.git"
  },
  "author": "ashubisht",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ashubisht/notifibell/issues"
  },
  "homepage": "https://github.com/ashubisht/notifibell#readme",
  "dependencies": {
    "@aws-sdk/client-ses": "^3.840.0",
    "@aws-sdk/client-sns": "^3.840.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "institute-scraper": "file:extract_institutes"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/express": "^4.17.23",
    "@types/node": "^22.15.32",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1"
  },
  "engines": {
    "node": ">=18"
  }
}
